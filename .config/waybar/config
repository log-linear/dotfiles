{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 25, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": [
        "niri/workspaces",
        "sway/mode",
        "custom/media",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "custom/nightlight",
        "idle_inhibitor",
        "custom/keyboard_icon",
        "sway/language",
    ],
    "modules-center": [
        "clock",
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "custom/pacman",
        "custom/printer",
        "custom/displays",
        "custom/browser",
        "custom/files",
        "custom/launcher",
        "custom/power",
        "battery",
        "battery#bat2",
    ],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 40
    },
    "sway/language": {
        "format": "{long}",
        "max-length": 30,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#94253e\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": " {icon} ",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "show-passive-items": true,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "format": "{:%a, %d %b  %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
    },
    "cpu": {
        "format": " яЛЫ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": " ґ░НЫ {}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": " {icon} {temperatureC}┬░C",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": " {icon} {percent}%",
        "format-icons": ["яЖЕ", "яДС"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЦГ",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЫ┐",
        "format-linked": "{ifname} (No IP) яЫ┐",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {icon} {volume}% {format_source} ",
        "format-bluetooth": " {icon} {volume}% яКФ {format_source}",
        "format-bluetooth-muted": "я▒Э {icon}яКФ {format_source}",
        "format-muted": "я▒Э {format_source}",
        "format-source": " яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЯН",
            "headset": "яЯН",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": " {icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format": " яАС ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Power/Log Off/Lock PC\"}'",
        "escape": true,
        "on-click": "exec swaynagmode --font 'SF Pro Display' -t warning -m '' -b ' Lock ' 'swaylock -f -c 000000' -b ' Logout ' 'swaymsg exit' -b ' Reboot ' 'systemctl reboot' -b ' Power off ' 'systemctl -i poweroff'" 
    },
    "custom/launcher": {
        "format": " {icon} ",
        "format-icons": {
            "default": "ґ░А╗"
        },
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Launch Application\"}'",
        "escape": true,
        "on-click": "exec alacritty --app-id=launcher -e /usr/bin/sway-launcher-desktop" 
    },
    "custom/files": {
        "format": " яРУ ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"File Manager\"}'",
        "escape": true,
        "on-click": "exec nautilus" 
    },
    "custom/browser": {
        "format": " юмБ ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Browser\"}'",
        "escape": true,
        "on-click": "exec firefox" 
    },
    "custom/displays": {
        "format": " ґ░Н║ ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Display Configuration\"}'",
        "escape": true,
        "on-click": "exec nwg-displays" 
    },
    "custom/printer": {
        "format": " ґ░Рк ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Printer Settings\"}'",
        "escape": true,
        "on-click": "exec system-config-printer" 
    },
    "custom/pacman": {
        "format": " {} ",
        "interval": 3600,                     // every hour
        "return-type": "json",
        "exec": "$HOME/.config/waybar/pacman_updates 2> /dev/null",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "tooltip-format": "{}",
        "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
        "signal": 8,
    },
    "custom/keyboard_icon": {
        "format": " {icon} ",
        "format-icons": {
            "default": "яДЬ"
        },
        "return-type": "json",
        "exec": "echo '{\"tooltip\": \"Switch Keyboard layout\"}'",
        "tooltip-format": "{}",
        "escape": true,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
    "custom/nightlight": {
        "format": " {icon} ",
        "format-icons": ["яЖЖ"],
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Toggle night light\"}'",
        "escape": true,
        "on-click": "exec wlsunset -t 4000 -T 4001" 
    },
}

