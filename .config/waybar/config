{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 25, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": [
        "niri/workspaces",
        "sway/mode",
        "custom/media",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "custom/nightlight",
        "idle_inhibitor",
        "custom/keyboard_icon",
        "sway/language",
    ],
    "modules-center": [
        "clock",
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "custom/pacman",
        "custom/printer",
        "custom/displays",
        "custom/browser",
        "custom/files",
        "custom/launcher",
        "custom/power",
        "battery",
        "battery#bat2",
    ],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 40
    },
    "sway/language": {
        "format": "{long}",
        "max-length": 30,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ⸨{songPosition}|{queueLength}⸩ {volume}% ",
        "format-disconnected": "Disconnected ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": " "
        },
        "random-icons": {
            "off": "<span color=\"#94253e\"></span> ",
            "on": " "
        },
        "repeat-icons": {
            "on": " "
        },
        "single-icons": {
            "on": "1 "
        },
        "state-icons": {
            "paused": "",
            "playing": ""
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": " {icon} ",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "tray": {
        // "icon-size": 21,
        "show-passive-items": true,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "format": "{:%a, %d %b  %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
    },
    "cpu": {
        "format": "  {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": " 🖫{}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}°C {icon}",
        "format": " {icon} {temperatureC}°C",
        "format-icons": [""]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": " {icon} {percent}%",
        "format-icons": ["", ""]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "Disconnected ⚠",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {icon} {volume}% {format_source} ",
        "format-bluetooth": " {icon} {volume}%  {format_source}",
        "format-bluetooth-muted": "ﱝ {icon} {format_source}",
        "format-muted": "ﱝ {format_source}",
        "format-source": "  {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": " {icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "",
            "default": "🎜"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format": "  ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Power/Log Off/Lock PC\"}'",
        "escape": true,
        "on-click": "exec swaynagmode --font 'SF Pro Display' -t warning -m '' -b ' Lock ' 'swaylock -f -c 000000' -b ' Logout ' 'swaymsg exit' -b ' Reboot ' 'systemctl reboot' -b ' Power off ' 'systemctl -i poweroff'" 
    },
    "custom/launcher": {
        "format": " {icon} ",
        "format-icons": {
            "default": "󰀻"
        },
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Launch Application\"}'",
        "escape": true,
        "on-click": "exec alacritty --app-id=launcher -e /usr/bin/sway-launcher-desktop" 
    },
    "custom/files": {
        "format": "  ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"File Manager\"}'",
        "escape": true,
        "on-click": "exec nautilus" 
    },
    "custom/browser": {
        "format": "  ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Browser\"}'",
        "escape": true,
        "on-click": "exec firefox" 
    },
    "custom/displays": {
        "format": " 󰍺 ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Display Configuration\"}'",
        "escape": true,
        "on-click": "exec nwg-displays" 
    },
    "custom/printer": {
        "format": " 󰐪 ",
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Printer Settings\"}'",
        "escape": true,
        "on-click": "exec system-config-printer" 
    },
    "custom/pacman": {
        "format": " {} ",
        "interval": 3600,                     // every hour
        "return-type": "json",
        "exec": "$HOME/.config/waybar/pacman_updates 2> /dev/null",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "tooltip-format": "{}",
        "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
        "signal": 8,
    },
    "custom/keyboard_icon": {
        "format": " {icon} ",
        "format-icons": {
            "default": ""
        },
        "return-type": "json",
        "exec": "echo '{\"tooltip\": \"Switch Keyboard layout\"}'",
        "tooltip-format": "{}",
        "escape": true,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
    },
    "custom/nightlight": {
        "format": " {icon} ",
        "format-icons": [""],
        "return-type": "json",
        "tooltip-format": "{}",
        "exec": "echo '{\"tooltip\": \"Toggle night light\"}'",
        "escape": true,
        "on-click": "exec wlsunset-toggle" 
    },
}

